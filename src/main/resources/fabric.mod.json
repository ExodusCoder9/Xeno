{
	"schemaVersion": 1,
	"id": "xeno",
	"version": "${version}",
	"name": "Xeno",
	"description": "Vulkan Based Rendering Engine Mod Forked from XCollateral's VulkanMod",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/xeno/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.xeno.Xeno"
		],
		"client": [
			"com.xeno.client.XenoClient"
		]
	},
	"mixins": [
		"xeno.mixins.json",
		{
			"config": "xeno.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}