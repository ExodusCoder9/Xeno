{
	"schemaVersion": 1,
	"id": "xeno",
	"version": "${version}",
	"name": "Xeno",
	"description": "A high-performance Vulkan rendering Mod for Minecraft, providing enhanced frame rates and reduced CPU overhead through certain rendering techniques.",
	"authors": [
		"ExodusCoder9"
	],
	"contact": {
		"homepage": "",
		"sources": ""
	},
	"license": "LGPL 3.0",
	"icon": "assets/xeno/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.xeno.Xeno"
		],
		"client": [
			"com.xeno.client.XenoClient"
		]
	},
	"mixins": [
		"xeno.mixins.json",
		{
			"config": "xeno.client.mixins.json",
			"environment": "client"
		}
	],
	"accessWidener": "xeno.accesswidener",
	"custom": {
		"fabric-renderer-api-v1:contains_renderer": true
	},
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}